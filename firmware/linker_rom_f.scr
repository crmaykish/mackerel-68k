MEMORY
{
    ROM(RX) : ORIGIN = 0xFF8000,  LENGTH = 0x800            /* 30 KB ROM region; 2 KB physical for now */
    RAM(RW) : ORIGIN = 0x400,  LENGTH = 0x2000 - 0x400      /* 8KB of RAM minus the vector table */
}

SECTIONS
{
    .vectors 0xFF8000 : { *(.vectors) } > ROM
    .text   : { *(.text*) } > ROM
    .rodata : { *(.rodata*) } > ROM
    .data : {
        _sdata = .;
        *(.data*)
        *(.sdata*)
        _edata = .;
    } > RAM AT > ROM
    _sidata = LOADADDR(.data);
    .bss (NOLOAD) : {
        _sbss = .;
        *(.bss*)
        *(COMMON)
        _ebss = .;
    } > RAM
    _end = .;
    _heap_end = ORIGIN(RAM) + LENGTH(RAM);
    stack_top = ORIGIN(RAM) + LENGTH(RAM);

    /* RAM info for the bootloader's `info` command */
    __sram_start = 0x00;
    __sram_length = 0x2000;
    __dram_start = 0x00;
    __dram_length = 0x00;
}
